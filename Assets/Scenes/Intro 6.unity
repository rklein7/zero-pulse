--- !u!114 &583253046
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 583253044}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e7c4d17d2ec30b3429138d788253ff3c, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::IntroManager
  slides:
  - titulo: 'A FLORESTA '
    texto: "O sinal some entre as \xE1rvores. Mas o Pulso n\xE3o pode parar.\n"
    imagem: {fileID: 2158891789428380870, guid: c314e9212d4a3cf4f8c88330ceed9a9e, type: 3}
    mostrarKael: 1
    posicaoKael: {x: -900, y: -300}
    kaelEspelhado: 0
  - titulo: "O SIL\xCANCIO "
    texto: "Al\xE9m da metr\xF3pole, o mundo est\xE1 quieto. Quieto demais. Algo
      aguarda entre as sombras da floresta.\n"
    imagem: {fileID: 8284087734974297348, guid: c314e9212d4a3cf4f8c88330ceed9a9e, type: 3}
    mostrarKael: 1
    posicaoKael: {x: -300, y: 0}
    kaelEspelhado: 0
  - titulo: "A FREQU\xCANCIA "
    texto: "O transmissor capta um eco vindo das profundezas. Uma c\xE9lula de energia
      \u2014 ou uma armadilha? Kael precisa avan\xE7ar.\n"
    imagem: {fileID: 2833043080597125133, guid: c314e9212d4a3cf4f8c88330ceed9a9e, type: 3}
    mostrarKael: 1
    posicaoKael: {x: 0, y: 200}
    kaelEspelhado: 0
  - titulo: CUIDADO
    texto: "A floresta n\xE3o tem paredes, mas tem dentes. Corra, Kael. O Pulso n\xE3o
      espera.\n"
    imagem: {fileID: 8676454946275842879, guid: c314e9212d4a3cf4f8c88330ceed9a9e, type: 3}
    mostrarKael: 1
    posicaoKael: {x: 200, y: 900}
    kaelEspelhado: 0
